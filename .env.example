# Environment Configuration Example
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# LLM Configuration (set to 'no_api' for built-in mode)
DEFAULT_LLM_PROVIDER=no_api
DEFAULT_MODEL=builtin

# API Keys (only needed if not using no_api mode)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Scraper Configuration
SYLLABUS_BASE_URL=https://example.com/syllabi
ALG_BASE_URL=https://www.collegeopenresources.org

# CORS Configuration (for React frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Application Settings
MAX_RESOURCES_PER_SEARCH=10
SEARCH_TIMEOUT=120
