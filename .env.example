# Environment Configuration Example
# Copy this file to .env and update values as needed

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# LLM Configuration (set to 'no_api' for built-in mode)
DEFAULT_LLM_PROVIDER=no_api
DEFAULT_MODEL=builtin

# Local LLM via Ollama (optional)
# DEFAULT_LLM_PROVIDER=ollama
# DEFAULT_MODEL=llama3.2:3b
# OLLAMA_BASE_URL=http://localhost:11434

# API Keys (only needed if not using no_api mode)
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Scraper Configuration
SYLLABUS_BASE_URL=https://example.com/syllabi
ALG_BASE_URL=https://www.collegeopenresources.org

# CORS (comma-separated). Must include your Netlify URL in production.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO

# Application Settings
MAX_RESOURCES_PER_SEARCH=10
SEARCH_TIMEOUT=120

# Supabase (optional) — also set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in frontend/.env.local for auth UI
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=  # only for legacy symmetric JWT projects
# SUPABASE_JWT_KID=     # optional: enforce expected kid from JWKS
# SUPABASE_JWKS_URL=    # default: ${SUPABASE_URL}/auth/v1/.well-known/jwks.json
# REQUIRE_AUTH_FOR_SAVES=true
# LEGACY_SAVED_USER_ID=00000000-0000-4000-8000-000000000001
